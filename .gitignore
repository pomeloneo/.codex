# This repo syncs reusable, reviewable Codex configuration across machines.
# Keep this as an explicit denylist so new shareable surfaces show up in
# `git status` instead of being silently hidden by a catch-all ignore rule.

# Credentials, local identity, and environment secrets.
auth.json
installation_id
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx

# Private or machine-specific Codex configuration.
# The current config includes local paths, project trust state, and internal
# endpoints, so keep it out of the public sync repo.
config.toml
config.local.toml
*.local.toml
hooks.json
rules/

# Conversation history, local state, and runtime databases.
.codex-global-state.json
.codex-global-state.json.bak
.personality_migration
history.jsonl
session_index.jsonl
sessions/
archived_sessions/
shell_snapshots/
ambient-suggestions/
memories/
goals_*.sqlite*
logs_*.sqlite*
memories_*.sqlite*
state_*.sqlite*
*.sqlite
*.sqlite-shm
*.sqlite-wal

# Logs, caches, generated artifacts, plugin installs, and bundled apps.
log/
logs/
cache/
models_cache.json
generated_images/
.tmp/
tmp/
sqlite/
plugins/
vendor_imports/
computer-use/
process_manager/
node_repl/
chrome-native-hosts.json
browser/

# Generated language artifacts and OS/editor noise.
__pycache__/
*.py[cod]
.DS_Store
.vscode/
.idea/

# Curated/system-managed skills are regenerated by Codex.
skills/.system/
skills/.system/**
